---
import Logo from "./Logo.astro";
import { SITE_CONFIG } from "../lib/site-config";

const links = SITE_CONFIG.links;

const navItems = [
    { name: "Home", href: links.home },
    { name: "Docs", href: links.docsHome },
    { name: "Blog", href: links.blog },
    { name: "Contact", href: links.contact },
];

const currentPath = Astro.url.pathname;
---

<div
    x-data="{
        mobileMenuOpen: false,
        scrolled: false,
        init() {
            window.addEventListener('scroll', () => {
                this.scrolled = window.scrollY > 20;
            });
        }
    }"
>
<header
    class="sticky top-0 z-50 w-full border-b border-brand-gray-200 bg-white transition-all duration-300"
    :class="scrolled ? 'shadow-sm' : ''"
>
    <div class="container-wide flex h-[100px] items-center justify-between">
        <div class="flex items-center gap-10">
            <a
                href="/"
                class="flex items-center gap-2 group shrink-0 transition-transform active:scale-95"
            >
                <Logo />
            </a>

            <nav class="hidden lg:flex items-center gap-8">
                {
                    navItems.map((navLink) => {
                        const isActive =
                            navLink.href === "/"
                                ? currentPath === "/"
                                : currentPath.startsWith(navLink.href);
                        return (
                            <a
                                href={navLink.href}
                                class:list={[
                                    "text-[18px] leading-none font-normal text-[var(--sgkb-header-nav)] transition-colors inline-flex items-center gap-1 whitespace-nowrap",
                                    isActive
                                        ? "text-brand-gray-900"
                                        : "hover:text-brand-gray-900",
                                ]}
                                target={
                                    navLink.href.startsWith("http")
                                        ? "_blank"
                                        : undefined
                                }
                                rel={
                                    navLink.href.startsWith("http")
                                        ? "noopener noreferrer"
                                        : undefined
                                }
                            >
                                {navLink.name}
                            </a>
                        );
                    })
                }
            </nav>
        </div>

        <div class="flex items-center gap-6">
            <a
                href={links.github}
                target="_blank"
                rel="noopener noreferrer"
                class="hidden sm:inline-flex items-center px-7 py-3 bg-primary text-white text-[18px] leading-none font-medium rounded-full hover:bg-primary-dark transition-all active:scale-95 whitespace-nowrap"
            >
                Get Started
            </a>

                <button
                    type="button"
                    @click="mobileMenuOpen = true"
                    class="lg:hidden p-2 text-brand-gray-600 hover:bg-brand-gray-100 rounded-lg transition-all active:scale-90 cursor-pointer"
                    aria-label="Toggle Menu"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <line x1="4" x2="20" y1="12" y2="12"></line>
                    <line x1="4" x2="20" y1="6" y2="6"></line>
                    <line x1="10" x2="20" y1="18" y2="18"></line>
                </svg>
            </button>
        </div>
    </div>
</header>

<!-- Mobile Navigation Drawer -->
<template x-teleport="body">
    <div
        x-show="mobileMenuOpen"
        class="fixed inset-0 z-[100] lg:hidden"
        style="display: none;"
    >
        <div
            x-show="mobileMenuOpen"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            @click="mobileMenuOpen = false"
            class="absolute inset-0 bg-brand-gray-900/50 backdrop-blur-sm"
        >
        </div>

        <div
            x-show="mobileMenuOpen"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="translate-x-full"
            x-transition:enter-end="translate-x-0"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="translate-x-0"
            x-transition:leave-end="translate-x-full"
            class="absolute inset-y-0 right-0 w-full max-w-xs bg-white shadow-2xl p-8 flex flex-col"
        >
            <div class="flex items-center justify-between mb-10">
                <div class="origin-left scale-[0.9]">
                    <Logo />
                </div>
                <button
                    type="button"
                    @click="mobileMenuOpen = false"
                    class="p-2 -mr-2 text-brand-gray-400 hover:text-brand-gray-900 bg-brand-gray-50 rounded-xl cursor-pointer"
                    aria-label="Close menu"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="M18 6 6 18"></path><path d="m6 6 12 12"
                        ></path></svg
                    >
                </button>
            </div>

            <nav class="flex flex-col gap-2">
                <a
                    href={links.home}
                    class="px-4 py-3 text-base font-medium rounded-xl transition-all flex items-center justify-between group text-brand-gray-900 hover:bg-brand-gray-50 hover:text-primary"
                    @click="mobileMenuOpen = false"
                >
                    Home
                </a>
                <a
                    href={links.docsHome}
                    class:list={[
                        "px-4 py-3 text-base font-medium rounded-xl transition-all flex items-center justify-between group",
                        currentPath.startsWith(links.docsHome) ? "bg-primary text-white" : "text-brand-gray-900 hover:bg-brand-gray-50 hover:text-primary",
                    ]}
                    @click="mobileMenuOpen = false"
                >
                    Docs
                </a>
                <a
                    href={links.blog}
                    class="px-4 py-3 text-base font-medium rounded-xl transition-all flex items-center justify-between group text-brand-gray-900 hover:bg-brand-gray-50 hover:text-primary"
                    @click="mobileMenuOpen = false"
                >
                    Blog
                </a>
                <a
                    href={links.contact}
                    class="px-4 py-3 text-base font-medium rounded-xl transition-all flex items-center justify-between group text-brand-gray-900 hover:bg-brand-gray-50 hover:text-primary"
                    @click="mobileMenuOpen = false"
                >
                    Contact
                </a>
            </nav>

            <div class="mt-auto pt-8 space-y-3 border-t border-brand-gray-100">
                <a
                    href={links.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="block w-full py-3 bg-primary text-white text-center font-bold rounded-xl active:scale-95 transition-all"
                    @click="mobileMenuOpen = false"
                >
                    Get Started
                </a>
            </div>
        </div>
    </div>
</template>
</div>
