---
import { Code } from "astro:components";

interface Props {
    code: string;
    lang?: any;
    title?: string;
    showLineNumbers?: boolean;
}

const {
    code,
    lang = "javascript",
    title,
    showLineNumbers = false,
} = Astro.props;
---

<div class="relative group my-8" x-data="{ copied: false }">
    {
        title && (
            <div class="bg-brand-gray-800 text-brand-gray-400 px-6 py-2.5 text-xs font-bold uppercase tracking-widest rounded-t-[1.5rem] border-b border-white/5 flex justify-between items-center">
                <span>{title}</span>
                <span class="text-[10px] bg-white/10 px-2 py-0.5 rounded uppercase">
                    {lang}
                </span>
            </div>
        )
    }

    <div
        class:list={[
            "relative overflow-hidden shadow-2xl",
            title ? "rounded-b-[1.5rem]" : "rounded-[1.5rem]",
        ]}
    >
        <Code
            code={code}
            lang={lang}
            theme="github-dark"
            class="!mt-0 !mb-0 !bg-[var(--sgkb-code-bg)] !p-6 text-sm"
        />

        <!-- Copy Button -->
        <button
            @click={`navigator.clipboard.writeText(\`${code.replace(/`/g, "\\`").replace(/\$/g, "\\$")}\`); copied = true; setTimeout(() => copied = false, 2000)`}
            class="absolute top-4 right-4 p-2 rounded-xl bg-white/5 hover:bg-white/10 text-white/50 hover:text-white transition-all opacity-0 group-hover:opacity-100 backdrop-blur-sm border border-white/10"
            :class="copied ? '!opacity-100 !bg-green-500/20 !text-green-400 !border-green-500/20' : ''"
            aria-label="Copy code"
        >
            <template x-if="!copied">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><rect width="14" height="14" x="8" y="8" rx="2" ry="2"
                    ></rect><path
                        d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
                    ></path></svg
                >
            </template>
            <template x-if="copied">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><polyline points="20 6 9 17 4 12"></polyline></svg
                >
            </template>
        </button>
    </div>
</div>
