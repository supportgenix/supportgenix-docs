---
import Logo from "./Logo.astro";
import { SITE_CONFIG } from "../lib/site-config";
import { getCategories } from "../lib/docs";

const currentYear = new Date().getFullYear();
const categories = await getCategories();

const quickLinks = [
  { name: "Home", href: SITE_CONFIG.links.home },
  { name: "Documentation", href: SITE_CONFIG.links.docsHome },
  { name: "About", href: SITE_CONFIG.links.about },
  { name: "Blog", href: SITE_CONFIG.links.blog },
  { name: "Contact", href: SITE_CONFIG.links.contact },
];

const legalLinks = [
  { name: "Terms & Conditions", href: SITE_CONFIG.links.terms },
  { name: "Privacy Policy", href: SITE_CONFIG.links.privacy },
];
---

<footer class="bg-[var(--sgkb-footer-bg)] text-[var(--sgkb-footer-text)] pt-20 pb-8 font-inter text-[18px]">
  <div class="container-wide">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.3fr_0.8fr_0.8fr_1fr] gap-10 lg:gap-14 mb-14"
    >
      <!-- Brand Column -->
      <div>
        <div class="mb-5">
          <Logo />
        </div>
        <p class="text-[var(--sgkb-footer-text)] text-[18px] leading-[1.55] mb-8 max-w-[34ch]">
          Your go-to resource for guides, tutorials, and documentation.
          Find answers quickly with our organized knowledge base and powerful search.
        </p>
        <div class="flex items-center gap-4">
          <a
            href={SITE_CONFIG.links.twitter}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Visit Twitter"
            class="inline-flex items-center justify-center w-10 h-10 bg-brand-gray-100 text-brand-gray-600 rounded-full hover:bg-primary hover:text-white transition-all"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
            ><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
          </a>
          <a
            href={SITE_CONFIG.links.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Visit GitHub"
            class="inline-flex items-center justify-center w-10 h-10 bg-brand-gray-100 text-brand-gray-600 rounded-full hover:bg-primary hover:text-white transition-all"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
            ><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path></svg>
          </a>
        </div>
      </div>

      <!-- Documentation -->
      <div>
        <h3 class="text-[20px] leading-none font-[600] mb-6 text-[var(--sgkb-footer-heading)]">
          Documentation
        </h3>
        <ul class="space-y-3">
          {
            categories.map((category) => (
              <li>
                <a
                  href={`/docs/category/${category.toLowerCase().replace(/\s+/g, "-")}`}
                  class="text-[18px] leading-[1.35] text-[var(--sgkb-footer-text)] hover:text-secondary-hover transition-colors"
                >
                  {category}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-[20px] leading-none font-[600] mb-6 text-[var(--sgkb-footer-heading)]">
          Quick Links
        </h3>
        <ul class="space-y-3">
          {
            quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-[18px] leading-[1.35] text-[var(--sgkb-footer-text)] hover:text-secondary-hover transition-colors"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Newsletter & Legal -->
      <div>
        <div
          class="bg-white border border-[var(--sgkb-footer-border)] rounded-2xl p-6 lg:min-w-[350px]"
        >
          <h3 class="text-[20px] leading-none font-[600] mb-6 text-[var(--sgkb-footer-heading)]">
            Stay Updated
          </h3>
          <p class="text-[18px] text-[var(--sgkb-footer-text)] leading-[1.55] mb-6">
            Subscribe to get notified about new articles, guides, and documentation updates.
          </p>
          {/*
            Newsletter form. The submit button is disabled until you wire this up
            to your provider (Mailchimp, ConvertKit, Buttondown, etc.).
            Set the form `action` to your provider endpoint and use `method="post"`,
            then remove the `disabled` attribute on the button below.
          */}
          <form class="relative mb-6" action="" method="post">
            <label for="newsletter-email" class="sr-only">Email address</label>
            <input
              id="newsletter-email"
              name="email"
              type="email"
              placeholder="Email Address"
              autocomplete="email"
              class="w-full h-12 pl-4 pr-14 bg-white border border-brand-gray-200 rounded-full focus:outline-none focus:ring-2 focus:ring-[var(--sgkb-focus-ring)] focus:border-primary focus:shadow-[var(--sgkb-focus-shadow)] text-[18px] text-[var(--sgkb-footer-text)] placeholder:text-[var(--sgkb-footer-text)] transition-all"
            />
            <button
              type="submit"
              disabled
              aria-label="Submit newsletter email"
              title="Configure your newsletter provider in src/components/Footer.astro"
              class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 bg-[var(--sgkb-footer-btn-bg)] rounded-full flex items-center justify-center hover:bg-[var(--sgkb-footer-btn-bg-hover)] transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="m5 12 14 0"></path><path d="m12 5 7 7-7 7"
                ></path></svg
              >
            </button>
          </form>
          <ul class="space-y-2">
            {
              legalLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-[14px] text-[var(--sgkb-footer-text)] hover:text-secondary-hover transition-colors"
                  >
                    {link.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-7 border-t border-[var(--sgkb-footer-bottom-border)] text-center">
      <p class="text-[var(--sgkb-footer-text)] text-[18px]">
        Copyright &copy; {currentYear}
        <a
          href={SITE_CONFIG.links.home}
          class="text-[var(--sgkb-footer-text)] hover:text-secondary-hover font-semibold transition-colors"
          >{SITE_CONFIG.organizationName}</a
        >. All rights reserved.
      </p>
    </div>
  </div>
</footer>
