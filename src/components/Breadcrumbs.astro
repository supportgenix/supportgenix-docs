---
interface Props {
    items: {
        label: string;
        href?: string;
    }[];
    variant?: "default" | "white";
}

const { items, variant = "default" } = Astro.props;

const textClass = variant === "white" ? "text-white/80" : "text-brand-gray-400";
const activeTextClass =
    variant === "white" ? "text-white" : "text-brand-gray-600";
const separatorClass =
    variant === "white" ? "text-white/40" : "text-brand-gray-300";
const hoverClass =
    variant === "white" ? "hover:text-white" : "hover:text-primary";
---

<nav aria-label="Breadcrumb" class="mb-4">
    <ol
        class:list={[
            "flex flex-wrap items-center gap-2 text-sm overflow-x-auto whitespace-nowrap pb-2 scrollbar-hide",
            textClass,
        ]}
        itemscope
        itemtype="https://schema.org/BreadcrumbList"
    >
        <li
            class="flex items-center gap-2"
            itemprop="itemListElement"
            itemscope
            itemtype="https://schema.org/ListItem"
        >
            <a
                href="/"
                itemprop="item"
                class:list={[
                    "transition-colors flex items-center gap-1.5",
                    hoverClass,
                ]}
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                    ></path><polyline points="9 22 9 12 15 12 15 22"
                    ></polyline></svg
                >
                <span itemprop="name">Home</span>
            </a>
            <meta itemprop="position" content="1" />
        </li>
        {
            items.map((item, index) => (
                <li
                    class="flex items-center gap-2"
                    itemprop="itemListElement"
                    itemscope
                    itemtype="https://schema.org/ListItem"
                >
                    <span class={separatorClass}>
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path d="m9 18 6-6-6-6" />
                        </svg>
                    </span>
                    {item.href ? (
                        <a
                            href={item.href}
                            itemprop="item"
                            class:list={["transition-colors", hoverClass]}
                        >
                            <span itemprop="name">{item.label}</span>
                        </a>
                    ) : (
                        <span
                            class:list={[
                                "font-medium truncate max-w-[200px]",
                                activeTextClass,
                            ]}
                            aria-current="page"
                            itemprop="name"
                        >
                            {item.label}
                        </span>
                    )}
                    <meta
                        itemprop="position"
                        content={(index + 2).toString()}
                    />
                </li>
            ))
        }
    </ol>
</nav>

<style>
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
